---
/* =========================
   🔥 AUTO LOAD ALL TOOLS
========================= */
const modules = Object.entries(
  import.meta.glob('/src/pages/tools/**/*.astro', { eager: true })
);

/* =========================
   🔥 FORMAT DATA
========================= */
const tools = modules
  .map(([file, mod]) => {
    if (!mod.meta) return null;

    let url = file.split('/pages')[1]?.replace('.astro', '') || '';
    if (!url.startsWith('/')) url = '/' + url;

    return { url, ...mod.meta };
  })
  .filter(Boolean);

/* =========================
   🔥 CURRENT URL
========================= */
const currentUrl = Astro.url.pathname.replace(/\/$/, '');

/* =========================
   🔥 HELPER FUNCTIONS
========================= */

// ambil kategori dari URL
function getCategory(url) {
  const parts = url.split('/').filter(Boolean);
  return parts[1] || null; // /tools/image/... => image
}

// ambil slug terakhir
function getSlug(url) {
  return url.split('/').pop() || '';
}

// grouping keyword (compress-image, resize-image, dll)
function getKeywordGroup(url) {
  const slug = getSlug(url);
  return slug.split('-').slice(0, 2).join('-');
}

/* =========================
   🔥 CURRENT CONTEXT
========================= */
const currentCategory = getCategory(currentUrl);
const currentGroup = getKeywordGroup(currentUrl);

/* =========================
   🔥 SCORING SYSTEM
========================= */
function scoreTool(tool) {
  let score = 0;

  if (getCategory(tool.url) === currentCategory) score += 3;
  if (getKeywordGroup(tool.url) === currentGroup) score += 5;

  // bonus kalau keyword mirip
  if (tool.title?.toLowerCase().includes(currentGroup.replace('-', ' '))) {
    score += 2;
  }

  return score;
}

/* =========================
   🔥 FILTER & SORT
========================= */
let relatedTools = tools
  .filter(t => t.url !== currentUrl)
  .map(t => ({
    ...t,
    score: scoreTool(t)
  }))
  .sort((a, b) => b.score - a.score);

/* =========================
   🔥 FALLBACK LOGIC
========================= */

// minimal harus relevan kategori
if (relatedTools.length < 3) {
  relatedTools = tools
    .filter(t =>
      getCategory(t.url) === currentCategory &&
      t.url !== currentUrl
    )
    .map(t => ({ ...t, score: scoreTool(t) }))
    .sort((a, b) => b.score - a.score);
}

// fallback global
if (relatedTools.length === 0) {
  relatedTools = tools
    .filter(t => t.url !== currentUrl)
    .map(t => ({ ...t, score: scoreTool(t) }))
    .sort((a, b) => b.score - a.score);
}

/* =========================
   🔥 LIMIT FINAL
========================= */
relatedTools = relatedTools.slice(0, 6);
---

{relatedTools.length > 0 && (
  <section class="related-tools">
    
    <h2>
      Tools Terkait {currentCategory ? `(${currentCategory})` : ''}
    </h2>

    <div class="tools-grid">
      {relatedTools.map(tool => (
        <a href={tool.url} class="tool-card">
          <h3>{tool.title}</h3>
          <p>{tool.description}</p>
        </a>
      ))}
    </div>

    {/* 🔥 INTERNAL LINK BOOST */}
    {currentCategory && (
      <div class="more-link">
        <a href={`/tools/${currentCategory}`}>
          Lihat semua tools {currentCategory} →
        </a>
      </div>
    )}

  </section>
)}

<style>
.related-tools {
  margin-top: 40px;
}

.related-tools h2 {
  margin-bottom: 15px;
  font-size: 20px;
}

/* GRID */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap: 15px;
}

/* CARD */
.tool-card {
  display: block;
  padding: 15px;
  border-radius: 12px;
  background: var(--card);
  border: 1px solid var(--border);
  text-decoration: none;
  color: var(--text);
  transition: 0.2s;
}

.tool-card:hover {
  border-color: var(--accent);
  transform: translateY(-3px);
}

/* TEXT */
.tool-card h3 {
  font-size: 0.95rem;
  margin-bottom: 5px;
}

.tool-card p {
  font-size: 0.8rem;
  color: var(--text-soft);
}

/* MORE LINK */
.more-link {
  margin-top: 15px;
  text-align: right;
}

.more-link a {
  font-size: 0.85rem;
  color: var(--accent);
  text-decoration: none;
}
</style>
