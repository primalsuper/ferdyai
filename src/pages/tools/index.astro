---
import MainLayout from "../../layouts/MainLayout.astro";

// ambil semua tools
const modules = Object.entries(
  import.meta.glob('./**/*.astro', { eager: true })
);

const tools = modules
  .map(([file, mod]) => {
    if (!mod.meta) return null;

    const url = file
      .replace('/src/pages', '')
      .replace('.astro', '');

    return { url, ...mod.meta };
  })
  .filter(Boolean);

// featured
const featured = tools.filter(t => t.featured);

// kategori auto
const categories = [...new Set(tools.map(t => t.category))];

// group by category
const grouped = {};
categories.forEach(cat => {
  grouped[cat] = tools.filter(t => t.category === cat);
});

// stats
const total = tools.length;

// SEO JSON-LD
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Free Online Tools",
  itemListElement: tools.map((tool, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: tool.title,
    url: `https://aimrferdy.net${tool.url}`
  }))
};
---

<MainLayout 
  title="Ai Mr Ferdy - Tools Online Gratis Lengkap"
  description="20+ tools Ai Mr Ferdy gratis: SEO, AI, converter, generator"
  url="https://aimrferdy.net/tools"
pageCSS={["tools"]}>

<div class="tools-container">

  <!-- HERO -->
  <section class="tools-hero">
    <h1>Ai Mr Ferdy -  All-in-One Tools Online</h1>
    <p>Gunakan tools Ai Mr Ferdy gratis tanpa install. Cepat & langsung pakai.</p>
  </section>

  <!-- STATS -->
  <section class="tools-stats">
    <div><strong>{total}</strong><span>Tools</span></div>
    <div><strong>{categories.length}</strong><span>Kategori</span></div>
    <div><strong>100%</strong><span>Gratis</span></div>
  </section>

  <!-- SEARCH -->
  <section class="tools-search">
    <input 
      id="searchTools"
      type="text"
      placeholder="Cari tools..."
      onInput="filterTools()"
    />
  </section>

  <!-- FEATURED -->
  {featured.length > 0 && (
    <section>
      <h2 class="section-title">🔥 Popular Tools</h2>

      <div class="tools-grid">
        {featured.map(tool => (
          <a href={tool.url} class="tool-card popular">
            <div class="badge">HOT</div>
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CATEGORY -->
  {categories.map(cat => (
    <section class="category">
      <div class="category-header" onclick="toggleCat(this)">
        {cat} <span>+</span>
      </div>

      <div class="category-content">
        {grouped[cat].map(tool => (
          <a href={tool.url} class="tool-card">
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}

  <!-- EMPTY -->
  <div id="emptyState" class="tools-empty" style="display:none;">
    Tidak ada tools ditemukan
  </div>

</div>

<!-- SCRIPT -->
<script>
window.filterTools = function () {
  const q = document.getElementById("searchTools").value.toLowerCase();
  const cards = document.querySelectorAll(".tool-card");
  let visible = 0;

  cards.forEach(card => {
    const match = card.innerText.toLowerCase().includes(q);
    card.style.display = match ? "block" : "none";
    if (match) visible++;
  });

  document.getElementById("emptyState").style.display = visible ? "none" : "block";
};

window.toggleCat = function (el) {
  const content = el.nextElementSibling;
  content.classList.toggle("active");

  const icon = el.querySelector("span");
  icon.textContent = content.classList.contains("active") ? "−" : "+";
};
</script>

<!-- SEO -->
<script type="application/ld+json">
{JSON.stringify(jsonLd)}
</script>

</MainLayout>
