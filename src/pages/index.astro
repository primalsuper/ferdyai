<style is:global>
:root{
  --shadow:0 10px 30px rgba(0,0,0,.12);
  --radius:24px;
  --gradient:linear-gradient(90deg,#ffffff,#dbeafe);
}

html.light-mode{
  --shadow:0 10px 30px rgba(0,0,0,.06);
  --gradient:linear-gradient(90deg,#0f172a,#2563eb);
}


.home-container{
  max-width:1180px;
  margin:auto;
  padding:30px 20px 80px;
}

/* HERO */
.tools-hero{
  position:relative;
  overflow:hidden;

  padding:80px 40px;
  border-radius:30px;

  background:
    radial-gradient(circle at top left, rgba(34,197,94,.12), transparent 35%),
    radial-gradient(circle at bottom right, rgba(34,197,94,.08), transparent 35%),
    var(--card);

  border:1px solid var(--border);

  text-align:center;
  margin-bottom:35px;

  box-shadow:var(--shadow);
}

.tools-hero h1{
  font-size:clamp(2rem,5vw,3.4rem);
  line-height:1.1;
  margin-bottom:20px;
  font-weight:800;
  letter-spacing:-1px;

  background:var(--gradient);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.seo-intro{
  max-width:760px;
  margin:auto;
  font-size:1.05rem;
  line-height:1.8;
  color:var(--muted);
}

/* BUTTON */
.btn{
  min-width:220px;
  height:56px;

  border-radius:16px;
  font-weight:700;
  font-size:15px;

  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:8px;

  text-decoration:none;
  transition:.3s ease;
}

.btn-primary{
  background:var(--accent);
  color:#fff;
  box-shadow:0 10px 25px rgba(0,0,0,.18);
}

.btn-primary:hover{
  transform:translateY(-3px);
}

.btn-secondary{
  background:var(--cardlink);
  color:var(--text);
  border:1px solid var(--border);
}

.btn-secondary:hover{
  border-color:var(--accent);
  transform:translateY(-3px);
}

/* STATS */
.tools-stats{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:18px;
  margin:35px 0 50px;
}

.tools-stats div{
  background:var(--card);
  border:1px solid var(--border);

  border-radius:20px;
  padding:28px 20px;

  text-align:center;

  transition:.3s ease;

  box-shadow:var(--shadow);
}

.tools-stats div:hover{
  transform:translateY(-5px);
}

.tools-stats strong{
  display:block;
  font-size:2rem;
  margin-bottom:8px;
  color:var(--accent);
}

.tools-stats span{
  color:var(--muted);
  font-size:.9rem;
}








.section-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px
}

.section-head h2{
  font-size:1.4rem;
  margin:0;
  display:flex;
  align-items:center;
  gap:6px
}

.section-head a{
  font-size:13px;
  color:var(--muted);
  transition:.2s
}

/* GRID */
.blog-list{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:16px;
  padding:0;
  list-style:none;
}

/* CARD */
.blog-list li{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:12px;
  padding:12px;
  transition:.25s;
}

.blog-list li:hover{
  transform:translateY(-4px);
  border-color:var(--accent);
  box-shadow:0 10px 25px rgba(0,0,0,.15);
}

.blog-list a{
  display:flex;
  flex-direction:column;
  gap:10px;
  height:100%;
}

/* IMAGE */
.thumb img{
  width:100%;
  height:140px;
  object-fit:cover;
  border-radius:8px;
}

/* TEXT */
.blog-list .title{
  font-size:.95rem;
  margin-bottom:4px;
}

.blog-list .desc{
  font-size:.8rem;
  color:var(--muted);
}

.blog-list .date{
  font-size:.75rem;
  color:var(--muted);
}

/* HOVER */
.blog-list li:hover .title,
.section-head a:hover{
  color:var(--accent)
}

/* RESPONSIVE */
@media(max-width:768px){
  .blog-list{
    grid-template-columns:repeat(2,1fr);
  }
}

@media(max-width:480px){
  .blog-list{
    grid-template-columns:1fr;
  }
}




.seo-box{
  background:var(--card);
  border:1px solid var(--border);
  padding:20px;
  border-radius:16px;
  margin-bottom:20px;
}

.seo-box h2{
  font-size:1.3rem;
  margin-bottom:10px;
}

.seo-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:15px;
}

.seo-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:16px;
  transition:.25s;
}

.seo-card:hover{
  border-color:var(--accent);
  transform:translateY(-3px);
}

.seo-card h3{
  font-size:1rem;
  margin-bottom:8px;
}

.seo-card p,
.seo-card li{
  font-size:.85rem;
  color:var(--muted);
}

.seo-card ul{
  padding-left:16px;
}

@media(max-width:768px){
  .seo-grid{
    grid-template-columns:1fr;
  }
}
.seo-faq{
  margin-top:25px;
  padding:18px;
  border:1px dashed var(--border);
  border-radius:14px;
}

.seo-faq h3{
  font-size:1rem;
  margin-bottom:10px;
}
.seo-heading{
  font-size:1.2rem;
  margin:10px 0 10px;
}
.seo-entity{
  margin-top:40px;
  padding:25px;
  background:linear-gradient(180deg, transparent, rgba(255,255,255,0.02));
  border-radius:18px;
}
.seo-tags{
  margin-top:15px;
  display:flex;
  flex-wrap:wrap;
  gap:8px;
}

.seo-tags span{
  font-size:.75rem;
  padding:6px 10px;
  border:1px solid var(--border);
  border-radius:999px;
  color:var(--muted);
}

</style>
</MainLayout>
