  </section>

  <!-- FEATURED TOOLS -->
  <section>
    <div class="section-head">
      <h2>🔥 Popular Tools</h2>
      <a href="/tools">Lihat semua →</a>
    </div>

    <div class="tools-grid">
      {featuredTools.map(tool => (
        <a href={tool.url} class="tool-card">
