  </section>

  <!-- BLOG -->
  <section>
    <div class="section-head">
      <h2>📚 Artikel Terbaru</h2>
      <a href="/blog">Lihat semua →</a>
    </div>

    <ul class="blog-list">
      {posts.map(post => (
        <li>
          <a href={`/blog/${post.id}/`}>
            <div class="thumb">
              <img src={post.data.heroImage} alt={post.data.title} />
            </div>

            <div>
              <h3 class="title">{post.data.title}</h3>
              <p class="date">
                {new Date(post.data.pubDate).toLocaleDateString()}
              </p>
