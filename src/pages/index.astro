---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE } from "../lib/site";
import { getCollection } from "astro:content";

const modules = Object.entries(
  import.meta.glob('./tools/**/*.astro', { eager: true })
);

const tools = modules
  .map(([file, mod]) => {
    if (!mod.meta) return null;

    const url = file
      .replace('/src/pages', '')
      .replace('.astro', '');

    return { url, ...mod.meta };
  })
  .filter(Boolean);

const featuredTools = tools.filter(t => t.featured).slice(0, 8);

const allPosts = await getCollection("blog");
const totalPosts = allPosts.length;

const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<MainLayout title="AI Tools Homepage" description="Merged homepage UI" canonical={SITE.url()}>

<div class="home-container">

  <!-- HERO -->
