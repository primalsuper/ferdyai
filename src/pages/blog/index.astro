---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<MainLayout 
  title="Blog AI Mr Ferdy"
  description="Artikel SEO, AI, dan tools online terbaru"
  url="https://aimrferdy.net/blog"
>

<section class="container blog-page">

  <h1>Artikel Terbaru</h1>

  <ul class="blog-list" id="blogList">
    {posts.map((post, i) => (
      <li class={i === 0 ? "featured" : ""}>

        <a href={`/blog/${post.id}/`}>

          <div class="thumb">
            <img 
              src={post.data.heroImage || "/default.jpg"} 
              alt={post.data.title}
              loading="lazy"
            />
          </div>

          <div class="content">
            <h2 class="title">{post.data.title}</h2>

            <p class="date">
              <FormattedDate date={post.data.pubDate} />
            </p>

            <p class="desc">
              {post.data.description?.slice(0, 120)}...
            </p>
          </div>

        </a>

      </li>
    ))}
  </ul>

</section>
<style>
/* BLOG PAGE (IMPROVED) */

.blog-page {
  max-width: 1000px;
  margin: auto;
}

/* LIST GRID */
.blog-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  list-style: none;
  padding: 0;
}

/* FEATURED */
.blog-list .featured {
  grid-column: 1 / -1;
}

.blog-list .featured .thumb {
  height: 300px;
}

/* CARD */
.blog-list li a {
  display: block;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: 0.25s;
}

.blog-list li a:hover {
  transform: translateY(-4px);
}

/* IMAGE FIX */
.thumb {
  width: 100%;
  height: 160px;
  overflow: hidden;
}

.thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* CONTENT */
.content {
  padding: 15px;
}

.title {
  font-size: 1rem;
  margin: 0 0 5px;
  line-height: 1.3;
}

.date {
  font-size: 0.8rem;
  color: var(--text-soft);
  margin-bottom: 6px;
}

.desc {
  font-size: 0.85rem;
  color: var(--text-soft);
}

/* MOBILE */
@media (max-width: 768px) {
  .blog-list {
    grid-template-columns: 1fr;
  }

  .blog-list .featured .thumb {
    height: 200px;
  }
}
</style>
</MainLayout>
